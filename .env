# Server configuration
PORT=8080
HOST=0.0.0.0

# JWT Authentication
JWT_SECRET=change_this_to_a_secure_random_string

# Development mode (disable real SMS)
DEV_MODE=1

# Twilio SMS API credentials (not needed in dev mode)
TWILIO_ACCOUNT_SID=placeholder_sid
TWILIO_AUTH_TOKEN=placeholder_token
TWILIO_FROM_NUMBER=+15555555555

# Database configuration
DB_PATH=./ab_macros_db

# Static files path (compiled frontend)
STATIC_FILES_PATH=./static

# Logging level: trace, debug, info, warn, error
RUST_LOG=info
